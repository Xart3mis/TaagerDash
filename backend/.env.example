DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/adtracker
SECRET_KEY=change-me-to-a-random-32-byte-hex-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Token encryption key (Fernet) — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=change-me-fernet-key

# Platform OAuth credentials (filled per platform)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:8000/api/platform/meta/callback

TIKTOK_APP_ID=
TIKTOK_APP_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8000/api/platform/tiktok/callback

SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REDIRECT_URI=http://localhost:8000/api/platform/snapchat/callback

# Frontend origin (for CORS)
FRONTEND_ORIGIN=http://localhost:5173
